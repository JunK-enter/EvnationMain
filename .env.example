# ─────────────────────────────────────────────────────────────────────────────
# evNation — environment variables (Next.js)
#
# Copy to `.env.local` for local development.
# Firebase/Pipedrive are optional — the app falls back to localStorage without them.
# ─────────────────────────────────────────────────────────────────────────────

# Copy to `.env.local` for local development (already created if you cloned fresh).
# evnation.us — connect only when deploying to production.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Firebase Realtime Database
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Pipedrive (optional)
NEXT_PUBLIC_PIPEDRIVE_API_TOKEN=
NEXT_PUBLIC_PIPEDRIVE_WEBHOOK_URL=

# Blog editors (optional — override defaults in src/data/blogEditors.js)
NEXT_PUBLIC_BLOG_EDITOR_1_EMAIL=editor@evnation.com
NEXT_PUBLIC_BLOG_EDITOR_1_PASSWORD=green111
NEXT_PUBLIC_BLOG_EDITOR_1_NAME=Blog Editor
NEXT_PUBLIC_BLOG_EDITOR_2_EMAIL=editor2@evnation.com
NEXT_PUBLIC_BLOG_EDITOR_2_PASSWORD=green222
NEXT_PUBLIC_BLOG_EDITOR_2_NAME=Blog Editor 2

# OpenAI (optional — chatbot uses local knowledge if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# YouTube featured video for homepage embed (optional — without this, play opens the channel)
# NEXT_PUBLIC_EVNATION_YOUTUBE_VIDEO_ID=

# VITE_FIREBASE_API_KEY= etc.
