# ─────────────────────────────────────────────────────────────────────────────
# EVnation Customer Intake System — environment variables
#
# Copy this file to `.env` and fill in real values to enable Firebase.
# If these are left empty, the app automatically falls back to localStorage
# so it keeps working in development without any backend.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Realtime Database (https://console.firebase.google.com/ -> Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Pipedrive integration (optional — used later by src/services/pipedrive.js)
# Use EITHER a direct API token OR a Zapier/Make webhook URL.
VITE_PIPEDRIVE_API_TOKEN=
VITE_PIPEDRIVE_WEBHOOK_URL=
